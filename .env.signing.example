# Copy to .env.signing (gitignored). Used by scripts/build-signed.ps1
#
# App Registration (Microsoft Entra ID):
#   Certificates & secrets -> New client secret
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Artifact Signing account (Azure portal -> your account -> Overview)
# Endpoint examples: https://eus.codesigning.azure.net  https://wus2.codesigning.azure.net
AZURE_TRUSTED_SIGNING_ENDPOINT=
AZURE_TRUSTED_SIGNING_ACCOUNT_NAME=
AZURE_CERTIFICATE_PROFILE_NAME=

# Tauri auto-updater signing (separate from Azure installer signing).
# Generate once: npm run tauri signer generate -- -w ~/.tauri/wavetrace.key --ci
# Paste the full contents of wavetrace.key (not the .pub file) into GitHub secret
# TAURI_SIGNING_PRIVATE_KEY, or set the path below for local signed builds.
TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PATH=%USERPROFILE%\.tauri\wavetrace.key
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
